name: "opensoc:ip:softmax"
description: "Softmax pipeline with LUT-based exp() and fixed-point arithmetic"
filesets:
  rtl:
    files:
      - rtl/exp_lut.sv
      - rtl/softmax_core.sv
      - rtl/softmax.sv
    file_type: systemVerilogSource

targets:
  default:
    filesets:
      - rtl
