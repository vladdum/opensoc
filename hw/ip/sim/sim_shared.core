name: "opensoc:ip:sim_shared"
description: "Simulation peripherals (simulator_ctrl, timer, ram_1p) — originally from lowRISC Ibex"

filesets:
  files_rtl:
    files:
      - simulator_ctrl.sv
      - timer.sv
      - ram_1p.sv
    file_type: systemVerilogSource

targets:
  default:
    filesets: [files_rtl]
