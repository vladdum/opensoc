name: "opensoc:ip:ram"
description: "Technology-dispatch RAM wrapper (XPM for FPGA, Sky130 stub for ASIC, ram_1p for sim)"

filesets:
  rtl:
    depend:
      - lowrisc:ibex:sim_shared
    files:
      - rtl/opensoc_ram.sv
    file_type: systemVerilogSource

targets:
  default:
    filesets:
      - rtl
