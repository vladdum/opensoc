name: "opensoc:fpga:arty_a7"
description: "OpenSoC FPGA build for Digilent Arty A7-100T (Artix-7 XC7A100T)"

filesets:
  files_rtl:
    depend:
      - "opensoc:soc:opensoc_top"
    files:
      - hw/fpga/arty_a7/opensoc_fpga_arty_a7_top.sv
    file_type: systemVerilogSource

  files_constraints:
    files:
      - hw/fpga/arty_a7/arty_a7.xdc
    file_type: xdc

targets:
  synth:
    default_tool: vivado
    filesets:
      - files_rtl
      - files_constraints
    toplevel: opensoc_fpga_arty_a7_top
    tools:
      vivado:
        part: xc7a100tcsg324-1
    parameters:
      - SYNTHESIS=true
      - FPGA_XILINX=true

parameters:
  SYNTHESIS:
    datatype: bool
    default: true
    paramtype: vlogdefine
    description: "Defined during FPGA synthesis to select direct clock assignment"
  FPGA_XILINX:
    datatype: bool
    default: true
    paramtype: vlogdefine
    description: "Enables Xilinx-specific pragmas and block RAM inference"
